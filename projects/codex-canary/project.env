# Switchboard project binding for the isolated Codex Stage 5B canary.
# Secrets stay in ~/.config/switchboard/app.env, never in this file.
SB_PROJECT_SLUG=codex-canary
SB_WORKFLOW_TEMPLATE=codex-canary
SB_GITHUB_REPO=colin-prologue/switchboard-codex-canary
SB_BASE_BRANCH=main
SB_WORKSPACE_ROOT=/Users/colindwan/Developer/switchboard-workspaces/codex-canary
SB_CONVENTION_ROOT=
