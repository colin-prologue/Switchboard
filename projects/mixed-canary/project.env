# Switchboard project binding for the isolated Stage 6 mixed-provider canary.
# This binding is inert until a separate synthetic repository is provisioned and
# an operator explicitly starts the mixed process. Secrets stay outside git.
SB_PROJECT_SLUG=mixed-canary
SB_WORKFLOW_TEMPLATE=mixed-canary
SB_GITHUB_REPO=colin-prologue/switchboard-mixed-canary
SB_BASE_BRANCH=main
SB_WORKSPACE_ROOT=/Users/colindwan/Developer/switchboard-workspaces/mixed-canary
SB_CONVENTION_ROOT=
