# Switchboard project binding for 'switchboard-self'. Sourced and exported by run-project.sh
# so the workspace hooks can see it. Secrets stay in the environment, not here.
SB_PROJECT_SLUG=switchboard-self
SB_GITHUB_REPO=colin-prologue/Switchboard
SB_BASE_BRANCH=main
SB_WORKSPACE_ROOT=/Users/colindwan/Developer/switchboard-workspaces/switchboard-self
SB_CONVENTION_ROOT=self/
# GITHUB_TOKEN is expected from the environment (GitHub App installation token).
